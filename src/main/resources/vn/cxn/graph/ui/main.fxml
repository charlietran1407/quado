<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="900.0" spacing="15.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vn.cxn.graph.controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" styleClass="header-box">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="header-title" text="VISUAL CODE GRAPH INDEXER" />
            <Label styleClass="header-subtitle" text="Hệ thống phân tích cú pháp mã nguồn &amp; Nhúng đồ thị ArcadeDB" />
        </VBox>
    </HBox>

    <!-- Configuration Pane -->
    <TitledPane animated="false" collapsible="false" styleClass="config-pane" text="CẤU HÌNH THƯ MỤC NGUỒN">
        <VBox spacing="10.0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="120.0" styleClass="field-label" text="Đường dẫn quét:" />
                <TextField fx:id="pathField" styleClass="path-field" HBox.hgrow="ALWAYS" />
                <Button onAction="#handleBrowse" styleClass="btn-browse" text="Chọn thư mục" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Operations & Control Pane -->
    <HBox spacing="15.0">
        <!-- Indexing Actions -->
        <TitledPane animated="false" collapsible="false" prefWidth="450.0" styleClass="action-pane" text="ĐIỀU KHIỂN QUÉT MÃ NGUỒN" HBox.hgrow="ALWAYS">
            <VBox spacing="12.0">
                <HBox spacing="10.0">
                    <Button fx:id="btnScan" onAction="#handleScan" prefWidth="140.0" styleClass="btn-primary" text="Bắt đầu quét code" />
                    <Button fx:id="btnClean" onAction="#handleClean" prefWidth="120.0" styleClass="btn-danger" text="Dọn dẹp DB" />
                </HBox>
                <Label fx:id="statusText" styleClass="status-text" text="Trạng thái: Sẵn sàng." />
                <ProgressBar fx:id="progressBar" prefHeight="15.0" prefWidth="400.0" progress="0.0" styleClass="progress-bar" />
            </VBox>
        </TitledPane>

        <!-- MCP Server Actions -->
        <TitledPane animated="false" collapsible="false" prefWidth="450.0" styleClass="action-pane" text="MCP SERVER CONTROL" HBox.hgrow="ALWAYS">
            <VBox spacing="12.0">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button fx:id="btnToggleMcp" onAction="#handleToggleMcp" prefWidth="180.0" styleClass="btn-secondary" text="Tắt MCP Server (SSE)" />
                    <Label fx:id="mcpStatusLabel" styleClass="status-badge-online" text="ONLINE" />
                </HBox>
                <Label styleClass="info-label" text="AI Client có thể kết nối thông qua URL:" />
                <TextField fx:id="mcpUrlField" editable="false" styleClass="mcp-url-field" text="http://localhost:3000/sse" />
            </VBox>
        </TitledPane>
    </HBox>

    <!-- Console log output -->
    <VBox spacing="5.0" VBox.vgrow="ALWAYS">
        <Label styleClass="field-label" text="NHẬT KÝ TIẾN TRÌNH (LOG CONSOLE):" />
        <TextArea fx:id="logConsole" editable="false" prefHeight="250.0" styleClass="log-console" VBox.vgrow="ALWAYS" />
    </VBox>
</VBox>
